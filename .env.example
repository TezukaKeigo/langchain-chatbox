# ============================================================
# 敏感配置模板（提交到 Git）
# 复制为 .env 后填入真实值，.env 不会被 Git 追踪
# ============================================================

# ----- LLM API 配置 -----
# 必填：LLM 服务提供商的 API Base URL
#   示例（OpenAI 官方）:   https://api.openai.com/v1
#   示例（DeepSeek）:      https://api.deepseek.com/v1
#   示例（Ollama 本地部署）: http://127.0.0.1:11434/v1
API_BASE_URL=https://api.openai.com/v1

# 必填：你的 API Key
API_KEY=sk-your-api-key-here

# 可选：默认使用的模型名称（不填则使用 config.yaml 中的默认值）
MODEL_NAME=gpt-4o-mini

# ----- 数据库配置（MySQL 生产部署用）-----
# MySQL 主机地址
MYSQL_HOST=localhost

# MySQL 端口
MYSQL_PORT=3306

# MySQL 用户名
MYSQL_USER=root

# MySQL 密码（生产环境务必使用强密码）
MYSQL_PASSWORD=

# MySQL 数据库名
MYSQL_DATABASE=langchain_chat

# ----- 运行环境 -----
# dev | test | prod（默认 dev）
APP_ENV=dev
