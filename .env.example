# ============================================================
# 敏感配置模板（提交到 Git）
# 复制为 .env 后填入真实值，.env 不会被 Git 追踪
# ============================================================

# ----- 各模型 API 配置 -----
# 每个模型使用各自厂商的 API Key 和 Base URL
# 只配置你实际使用的模型即可，未配置的模型会回退到下面的「通用回退」

# --- DeepSeek ---
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# --- Kimi（Moonshot）---
KIMI_API_KEY=sk-your-kimi-api-key
KIMI_API_BASE=https://api.moonshot.cn/v1

# --- Qwen（阿里云通义千问）---
QWEN_API_KEY=sk-your-qwen-api-key
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# ----- 通用回退（当上述特定模型的 key 未配置时使用）-----
# 如果你只有一个 API key 且想用于所有模型，只需填下面的值
API_BASE_URL=https://api.deepseek.com/v1
API_KEY=sk-your-api-key-here

# 可选：默认使用的模型名称（不填则使用 config.yaml 中的默认值）
MODEL_NAME=deepseek-v4-flash

# ----- 数据库配置（MySQL 生产部署用）-----
# MySQL 主机地址
MYSQL_HOST=localhost

# MySQL 端口
MYSQL_PORT=3306

# MySQL 用户名
MYSQL_USER=root

# MySQL 密码（生产环境务必使用强密码）
MYSQL_PASSWORD=

# MySQL 数据库名
MYSQL_DATABASE=langchain_chat

# ----- 运行环境 -----
# dev | test | prod（默认 dev）
APP_ENV=dev
